<section class="flex-center w-screen py-40" id="contact">
  <div class="section flex-center space-y-20 flex-col">
    <h2 class="text-4xl font-timesten font-bold">
      Vamos a construir algo grande
    </h2>

    <form
      id="contact-form"
      class="glass-card w-[80dvw] min-w-3/6 max-w-150 rounded-xl p-6 flex items-start flex-col justify-start"
    >
      <div class="w-full space-y-3">
        <h3 class="font-mono text-sm text-secondary uppercase">
          Escribe tu idea
        </h3>

        <textarea
          name="message"
          placeholder="Hola Ángel, me gustaría hablar sobre..."
          rows="5"
          required
          class="w-full border-white/10 border rounded-xl font-timesten p-2 scrollbar-gutter-stable"
        ></textarea>
      </div>

      <div class="flex flex-1 items-end justify-end w-full mt-10">
        <button
          type="submit"
          class="border border-white/10 font-timesten px-8 py-4 text-secondary rounded-lg bg-neutral-800/60 hover:shadow-lg/60 transition-all shadow-white/10"
        >
          Enviar
        </button>
      </div>

      <p id="status" class="mt-4 text-sm text-secondary"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    const response = await fetch("/api/contact", {
      method: "POST",
      body: JSON.stringify({
        message: formData.get("message"),
      }),
      headers: {
        "Content-Type": "application/json",
      },
    });

    if (response.ok) {
      status.textContent = "Mensaje enviado correctamente.";
      form.reset();
    } else {
      status.textContent = "Error enviando el mensaje.";
    }
  });
</script>
---
import Badge from "./Badge.astro";

const { title, description, stack, demo, code, image } = Astro.props;
---

<div class="glass-card rounded-xl overflow-hidden flex flex-col items-center">
  <div class="w-auto h-64 overflow-hidden">
    <img 
      src={image} 
      alt=`Imagen de mi proyecto titulado: "${title}"`
      class="h-full w-full object-cover"
    >
  </div>
  <div class="w-5/6 space-y-8 mt-5 flex flex-col">
    <div class="py-5 font-timesten">
      <h3 class="text-2xl font-bold mb-3">{title}</h3>
      <p class="text-secondary text-md">{description}</p>
    </div>
    <div class="flex-1">
      {stack.map((i) => <Badge small={true} name={i} />)}
    </div>
    <div class="h-px my-5 bg-neutral-800 rounded-full w-full"></div>
    <div class="flex items-center justify-between mb-10">
      <a href={demo} class="text-sm text-accent/70 transition-colors duration-100 hover:text-accent  inline-flex gap-2 items-center font-mono" target="_blank">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          ></path>
        </svg>
        Live Demo
      </a>
      {
        code ? (
          <a
            href={code}
            target="_blank"
            class="inline-flex gap-2 items-center text-secondary text-sm font-mono"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
              />
            </svg>
            Código
          </a>
        ) : (
          <a class="inline-flex gap-2 items-center text-secondary text-sm font-mono">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"
              />
            </svg>
            Privado
          </a>
        )
      }
    </div>
  </div>
</div>
